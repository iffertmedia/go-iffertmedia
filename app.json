{
  "expo": {
    "name": "GO Iffert Media",
    "slug": "go-iffert",
    "scheme": "vibecode",
    "version": "1.1.3",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.goiffertmedia",
      "buildNumber": "3",
    },
    "android": {
  "package": "com.iffertmedia.goiffertmedia",
  "edgeToEdgeEnabled": true
},
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png"
  }
}
